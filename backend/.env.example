# --- Servidor ---
PORT=3000
NODE_ENV=development

# --- Base de datos (PostgreSQL local vía Docker) ---
DATABASE_URL=postgresql://uceconnect_user:uceconnect_pass@localhost:5432/uceconnect

# --- Autenticación (JWT) ---
JWT_SECRET=uceconnect_jwt_secret_local_dev
JWT_REFRESH_SECRET=uceconnect_refresh_secret_local_dev
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# --- Correo electrónico (Nodemailer) ---
EMAIL_USER=tu_correo@gmail.com
EMAIL_PASS=tu_app_password_gmail

# --- Inteligencia artificial (Google Gemini vía OpenRouter) ---
OPENROUTER_API_KEY=your_openrouter_api_key_here

# --- Almacenamiento de archivos (Cloudinary) ---
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# --- Frontend (CORS) ---
FRONTEND_URL=http://localhost:5173

# --- Autenticación con Microsoft (Azure AD) ---
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_TENANT_ID=your-microsoft-tenant-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
MICROSOFT_REDIRECT_URI=http://localhost:3000/api/v1/auth/microsoft/callback
