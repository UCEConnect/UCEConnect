{
  "name": "uceconnect-backend",
  "version": "1.0.0",
  "description": "API REST para la gestión de incidencias estudiantiles de la Universidad Central del Ecuador (UCEConnect)",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "docker:local": "docker-compose -f docker-compose.local.yml up -d",
    "docker:local:down": "docker-compose -f docker-compose.local.yml down",
    "docker:local:logs": "docker-compose -f docker-compose.local.yml logs -f",
    "docker:build": "docker build -f Dockerfile.backend -t wadri/uceconnect-backend:dev .",
    "docker:push": "docker push wadri/uceconnect-backend:dev"
  },
  "author": "Adrian Lumbi",
  "license": "MIT",
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  },
  "dependencies": {
    "@azure/msal-node": "^2.16.2",
    "@sentry/nestjs": "^10.59.0",
    "axios": "^1.18.1",
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.4.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^9.0.1",
    "openai": "^4.56.0",
    "pg": "^8.12.0",
    "winston": "^3.19.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "jest": "^25.0.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0"
  }
}
